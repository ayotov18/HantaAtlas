{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run *:*)",
      "Bash(npm test:*)",
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npx vitest run*)",
      "Bash(npx prisma *)",
      "Bash(npx tsc --noEmit*)",
      "Bash(xcodebuild *)",
      "Bash(xcrun simctl *)",
      "Bash(swift *)",
      "Bash(sips *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git fetch*)",
      "Bash(grep *)",
      "Bash(find . *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(docker compose ps)",
      "Bash(docker compose logs*)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git rm *)",
      "Bash(git reset *)",
      "Bash(git checkout *)",
      "Bash(docker compose up*)",
      "Bash(docker compose down*)",
      "Bash(npm run prisma:migrate*)",
      "Bash(npm run prisma:seed*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(*--no-verify*)",
      "Bash(*--no-gpg-sign*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-dangerous-bash.sh"
          }
        ]
      }
    ]
  },
  "outputStyle": "default"
}
