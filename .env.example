# HantaAtlas — example environment file.
# Copy to `.env` (gitignored, never commit it) and fill in your own values.

# ─── Runtime ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0              # 0.0.0.0 in Docker; 127.0.0.1 for bare-metal behind a proxy
LOG_LEVEL=info
SEED_TIMEZONE=Europe/Sofia

# ─── CORS ───────────────────────────────────────────────────────────────────
# The iOS app does not need CORS (URLSession is not a browser). Set this to your
# marketing-site origin if you run one; "*" is fine for local development.
CORS_ORIGIN=*

# ─── Database ───────────────────────────────────────────────────────────────
# docker compose injects DATABASE_URL automatically from POSTGRES_PASSWORD.
# Only set DATABASE_URL yourself when running Postgres outside Docker.
POSTGRES_PASSWORD=change-me-to-a-strong-random-value
# DATABASE_URL=postgresql://hantaatlas:change-me-to-a-strong-random-value@127.0.0.1:5432/hantaatlas

# ─── Reverse-proxy ingress (so an iOS *device* can reach your local backend) ──
# Pick ONE path (see README → "Run the backend"). Both are opt-in compose profiles.
#
# Caddy (docker compose --profile proxy up): public domain whose DNS points here.
APP_DOMAIN=api.example.com
ACME_EMAIL=you@example.com
#
# Cloudflare Tunnel (docker compose --profile tunnel up): no public IP needed.
# Create a free named tunnel in the Cloudflare Zero Trust dashboard and paste
# its token here.
CLOUDFLARE_TUNNEL_TOKEN=

# ─── Marketing site (optional, Next.js) ─────────────────────────────────────
# NEXT_PUBLIC_API_URL=https://api.example.com
# NEXT_PUBLIC_SITE_URL=https://example.com

# ─── Apple Push Notifications (optional) ────────────────────────────────────
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=com.example.hantaatlas
APNS_KEY_PATH=./secrets/AuthKey.p8
APNS_USE_SANDBOX=true
