[Unit]
Description=Encrypted nightly backup (Postgres + configs)
After=postgresql.service

[Service]
Type=oneshot
User=root
EnvironmentFile=/etc/hantaatlas/secrets.env
ExecStart=/bin/bash -c 'AGE_RECIPIENTS="$(grep -vE "^(#|$)" /etc/hantaatlas/backup-recipients.txt | tr "\n" " ")" /usr/local/sbin/hantaatlas-backup'
